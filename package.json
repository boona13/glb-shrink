{
  "name": "glb-shrink",
  "version": "1.0.0",
  "description": "Compress GLB 3D models for games, apps, and real-time 3D — before/after preview with Draco + WebP",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"node server/index.mjs\"",
