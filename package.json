    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "cors": "^2.8.5",
    "draco3dgltf": "^1.5.7",
    "express": "^4.21.2",
    "meshoptimizer": "^1.1.1",
    "multer": "^1.4.5-lts.2",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=18"
  }
}
